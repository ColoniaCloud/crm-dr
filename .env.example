# Base de datos MySQL (Prisma)
DATABASE_URL=                 # mysql://usuario:password@host:3306/nombre_db

# NextAuth v5 — Autenticación
NEXTAUTH_SECRET=              # Genera con: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=                  # Mismo valor que NEXTAUTH_SECRET
AUTH_URL=http://localhost:3000

# Anthropic — IA (AI Insights, Social Creator)
ANTHROPIC_API_KEY=            # Clave de https://console.anthropic.com

# Google Maps — Scrapper de leads geolocalizado
GOOGLE_MAPS_API_KEY=          # Clave de https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=  # Misma clave (para embeds de mapa en el frontend)

# Email (SMTP) — Notificaciones y envío de presupuestos
SMTP_HOST=                    # Ej: smtp.hostinger.com
SMTP_PORT=587                 # 587 para STARTTLS, 465 para SSL
SMTP_SECURE=false             # true si el puerto es 465
SMTP_USER=                    # Email del remitente
SMTP_PASS=                    # Contraseña del email
SMTP_FROM=                    # Email que aparece como remitente

# WhatsApp — Enlace en emails de presupuestos
WHATSAPP_DEFAULT_NUMBER=      # Número de WhatsApp fallback en formato internacional sin + (ej: 5491112345678)

# Logging — Nivel de log de Pino
LOG_LEVEL=info                # Opciones: fatal, error, warn, info, debug, trace

# Seed — Contraseñas iniciales (prisma db seed)
SEED_ADMIN_PASSWORD=          # Password del admin. Si no se define, se genera una aleatoria
SEED_OPERATOR_PASSWORD=       # Password del operador. Si no se define, se genera una aleatoria
